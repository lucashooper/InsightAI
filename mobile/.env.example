# Mira chat screenshot modes (see data/screenshotMiraChat.ts):
#   EXPO_PUBLIC_MIRA_SCREENSHOT=messages  — demo Q&A bubbles
#   EXPO_PUBLIC_MIRA_SCREENSHOT=blank     — empty chat thread for Figma comps
# Remove when done capturing.
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_MIRA_SCREENSHOT=1

# RevenueCat Configuration
REVENUECAT_API_KEY=your_revenuecat_public_sdk_key_here

# IMPORTANT: Email Configuration (Resend)
# The Resend API key should ONLY be configured in Supabase Dashboard
# under Project Settings > Authentication > SMTP Settings
# It should NEVER be included in the mobile app code or .env file
# Supabase handles all email sending server-side using SMTP credentials
